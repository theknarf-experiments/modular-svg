{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "SceneNode",
	"type": "object",
	"properties": {
		"type": {
			"type": "string",
			"enum": [
				"Group",
				"Rect",
				"Circle",
				"Background",
				"StackV",
				"StackH",
				"Align",
				"Distribute",
				"Ref",
				"Text",
				"Arrow",
				"Line",
				"Image",
				"Path",
				"Span"
			]
		},
		"id": { "type": "string" },
		"props": {
			"type": "object",
			"properties": {
				"width": { "type": "number" },
				"height": { "type": "number" },
				"x": { "type": "number" },
				"y": { "type": "number" },
				"r": { "type": "number" },
				"cx": { "type": "number" },
				"cy": { "type": "number" },
				"spacing": { "type": "number" },
				"total": { "type": "number" },
				"alignment": { "type": "string" },
				"axis": { "type": "string" },
				"direction": { "type": "string" },
				"fill": { "type": "string" },
				"stroke": { "type": "string" },
				"stroke-width": { "type": "number" },
				"text": { "type": "string" },
				"padding": { "type": "number" },
				"zOrder": { "type": "number" },
				"href": { "type": "string" },
				"d": { "type": "string" },
				"font-size": { "type": ["number", "string"] },
				"source": {
					"type": "array",
					"items": { "type": "number" },
					"minItems": 2,
					"maxItems": 2
				},
				"target": {
					"type": "array",
					"items": { "type": "number" },
					"minItems": 2,
					"maxItems": 2
				},
				"padStart": { "type": "number" },
				"padEnd": { "type": "number" }
			},
			"additionalProperties": true
		},
		"children": { "type": "array", "items": { "$ref": "#" } },
		"target": { "type": "string" }
	},
	"required": ["type"],
	"additionalProperties": false
}
